<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtStarCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Total: 0"
        android:textColor="@color/text_dark"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtStars"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/card_background"
        android:gravity="center"
        android:padding="28dp"
        android:text="Stars: No stars yet"
        android:textColor="@color/text_dark"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtNumbers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/card_background"
        android:gravity="center"
        android:padding="22dp"
        android:text="Play a game"
        android:textColor="@color/text_dark"
        android:textSize="32sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnCountStars"
        style="@style/SpeakButton"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/voice"
        android:text="🔊 Count Stars" />

    <Button
        android:id="@+id/btnResetStars"
        style="@style/SpeakButton"
        android:layout_marginTop="14dp"
        android:backgroundTint="@color/emotion_angry"
        android:text="Reset Stars" />

    <TextView
        android:id="@+id/txtRewardTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:text="Reward Time 🎉"
        android:textColor="@color/text_dark"
        android:textSize="34sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
</ScrollView>
