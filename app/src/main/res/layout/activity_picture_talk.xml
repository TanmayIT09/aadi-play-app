<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtPictureStars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="⭐ 0"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPictureTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Park"
            android:textColor="@color/text_dark"
            android:textSize="32sp"
            android:textStyle="bold" />

        <com.example.aadi_app.SceneDrawingView
            android:id="@+id/sceneDrawingView"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_background" />

        <Button
            android:id="@+id/btnSpeakPicture"
            style="@style/SpeakButton"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/voice"
            android:text="🔊 What is happening?" />

        <Button
            android:id="@+id/btnPictureOptionOne"
            style="@style/SlimButton"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/picture"
            android:text="Option 1" />

        <Button
            android:id="@+id/btnPictureOptionTwo"
            style="@style/SlimButton"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/routine"
            android:text="Option 2" />

        <Button
            android:id="@+id/btnPictureOptionThree"
            style="@style/SlimButton"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/reward"
            android:text="Option 3" />

        <Button
            android:id="@+id/btnPictureOptionFour"
            style="@style/SlimButton"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/emotion_sad"
            android:text="Option 4" />

        <Button
            android:id="@+id/btnPictureOptionFive"
            style="@style/SlimButton"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/tune"
            android:text="Option 5" />

        <Button
            android:id="@+id/btnNextPicture"
            style="@style/SpeakButton"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/voice"
            android:text="Next Picture" />

    </LinearLayout>
</ScrollView>
