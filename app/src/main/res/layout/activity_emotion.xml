<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtEmotionStars"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="⭐ 0"
        android:textColor="@color/text_dark"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtSelectedEmotion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/card_background"
        android:gravity="center"
        android:padding="28dp"
        android:text="😊"
        android:textSize="88sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtFeelingSentence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:text="How does this face feel?"
        android:textColor="@color/text_dark"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSpeakFeeling"
        style="@style/SpeakButton"
        android:layout_marginTop="18dp"
        android:backgroundTint="@color/voice"
        android:text="🔊 Listen" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnEmotionOptionOne"
            style="@style/BigButton"
            android:backgroundTint="@color/emotion_happy"
            android:text="Happy" />

        <Button
            android:id="@+id/btnEmotionOptionTwo"
            style="@style/BigButton"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/emotion_sad"
            android:text="Sad" />

    </LinearLayout>

</LinearLayout>
